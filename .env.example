# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust as needed. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# Application under test
BASE_URL=https://erp.progbiz.io

# Credentials (from the test-case document Cover sheet)
COMPANY_CODE=Testlive
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# Secondary / limited role user (used by RBAC cross-user cases in other modules)
USER_USERNAME=Kavyasree
USER_PASSWORD=123

# Execution
HEADLESS=true
# Timeouts (milliseconds)
TEST_TIMEOUT=60000
EXPECT_TIMEOUT=10000
ACTION_TIMEOUT=15000
NAV_TIMEOUT=30000

# Set to true only if the environment presents an invalid TLS certificate
IGNORE_HTTPS=false
